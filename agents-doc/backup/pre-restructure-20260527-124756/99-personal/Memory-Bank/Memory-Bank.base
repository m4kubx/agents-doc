---
# Memory Bank Index - Base de Conocimiento Viva del Vault

filters:
  and:
    - 'file.inFolder("99-personal/Memory-Bank")'
    - 'type == "memory"'

properties:
  type:
    displayName: "Tipo"
  last-updated:
    displayName: "Última Actualización"
  project:
    displayName: "Proyecto"

views:
  - type: table
    name: "Memoria por Tipo"
    order:
      - file.name
      - type
      - last-updated
      - project
    groupBy:
      property: type

  - type: cards
    name: "Vista de Memoria"
    order:
      - file.name
      - type
---
