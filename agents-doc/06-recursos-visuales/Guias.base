---
# Guías Detalladas - Base de la metodología Agents-Doc

filters:
  or:
    - 'type == "guia"'
    - 'file.name.startswith("guia-")'

properties:
  type:
    displayName: "Tipo"

views:
  - type: table
    name: "Guías por Nombre"
    order:
      - file.name
      - file.mtime
    groupBy:
      property: type

  - type: list
    name: "Lista de Guías"
    order:
      - file.name
---
